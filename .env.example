# Schwab
SCHWAB_API_KEY=
SCHWAB_APP_SECRET=
SCHWAB_CALLBACK_URL=

# Alpaca
APCA_API_KEY_ID=
APCA_API_SECRET_KEY=
APCA_API_BASE_URL=https://paper-api.alpaca.markets   # swap to https://api.alpaca.markets for live

# Postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=augur
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# Derived — used by services directly
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Collector poll intervals (seconds)
POLL_INTERVAL_POSITIONS=30
POLL_INTERVAL_QUOTES=60

# Paper fill model: mid | natural | worst
DEFAULT_FILL_MODEL=mid
